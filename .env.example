# ============================================
# DAVIS — AI Lead Engine Environment Variables
# Copy this to .env and fill in all values
# Add ALL of these as GitHub repo secrets too
# ============================================

# Your WhatsApp Group Invite Link
WHATSAPP_INVITE_LINK=https://chat.whatsapp.com/YOUR_LINK_HERE

# Google Gemini API (FREE — get at aistudio.google.com)
GEMINI_API_KEY=AIzaSy...

# Pexels API (FREE — get at pexels.com/api)
PEXELS_API_KEY=...

# YouTube API (FREE — get at console.cloud.google.com)
# This is a JSON object with token, refresh_token, client_id, client_secret
YOUTUBE_CLIENT_SECRETS_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"..."}

# Instagram Graph API (FREE — get at developers.facebook.com)
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_BUSINESS_ACCOUNT_ID=...

# Facebook Graph API (FREE — same Facebook Developer app as Instagram)
FB_ACCESS_TOKEN=...
FB_PAGE_ID=...

# Supabase (FREE — get at supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
